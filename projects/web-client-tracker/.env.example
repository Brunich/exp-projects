# Environment

# Public app URL (used for redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side client data file (created on first run with sample data)
CLIENTS_FILE=data/clients.json

# Optional SMTP for server-sent follow-up reminders (POST /api/clients/reminders)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-password
# SMTP_FROM=reminders@yourdomain.com

# Scheduled reminder cron (GET /api/cron/reminders via Vercel Cron)
# CRON_SECRET=generate-a-long-random-string
# REMINDER_CRON_SENDER_EMAIL=you@yourdomain.com
# REMINDER_CRON_SENDER_NAME=Your Name
